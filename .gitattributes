# Normalize line endings for cross-platform development.
* text=auto

# Source files should stay LF.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env.example text eol=lf

# Shell scripts should stay LF.
*.sh text eol=lf

# Windows command scripts can stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.xlsx binary
*.xls binary
*.docx binary
*.pptx binary
*.zip binary
